<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="80dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back"
            android:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="vertical"
            android:background="@drawable/white_card_background"
            android:padding="24dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet Functions"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:textColor="#6C4DFF"
                android:fontFamily="sans-serif-medium" />

            <Button
                android:id="@+id/buttonCheckBalance"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Check Balance"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_gradient"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonAddMoney"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Add Money"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_gradient"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonTransaction"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Transaction"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_gradient"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonSendMoney"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Send Money"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_gradient"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
